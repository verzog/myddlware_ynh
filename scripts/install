#!/bin/bash
set -eu

source /usr/share/yunohost/helpers
source "$(dirname "$0")/_common.sh"

#=================================================
# STORE APP-SPECIFIC SETTINGS
#=================================================
ynh_app_setting_set --app="$app" --key=admin --value="$admin"
ynh_app_setting_set --app="$app" --key=phpversion --value="$phpversion"

#=================================================
# FETCH SOURCES
#=================================================
ynh_script_progression --message="Fetching Myddleware sources" --weight=2
ynh_setup_source --dest_dir="$install_dir"
chown -R "$app:$app" "$install_dir"

#=================================================
# COMPOSER DEPENDENCIES
#=================================================
ynh_script_progression --message="Installing Composer" --weight=2
ynh_install_composer --phpversion="$phpversion" --workdir="$install_dir" --composerversion=2.7.7

ynh_script_progression --message="Installing PHP dependencies" --weight=10
# NB: Myddleware's config/bundles.php enables DoctrineFixturesBundle (a
# require-dev package) in the prod environment, so the kernel fails to boot
# with --no-dev. Dev dependencies must stay installed until upstream gates
# those bundles to dev/test only.
ynh_composer_exec --phpversion="$phpversion" --workdir="$install_dir" \
    --commands="install --optimize-autoloader"

#=================================================
# ADD WORDPRESS CONNECTOR
#=================================================
# Upstream references a 'wordpress' solution but never shipped an implementation
# (no class, just a dead import + field metadata). Provide one (REST API v2 with
# Application Password auth) and register it so it appears in the connector list
# and gets seeded by the fixtures step. Idempotent: guarded so it is safe if
# upstream ever ships its own.
ynh_script_progression --message="Adding the WordPress connector"
ynh_app_basedir="${YNH_APP_BASEDIR:-$(cd "$(dirname "$0")/.." && pwd)}"
cp "$ynh_app_basedir/conf/wordpress.php" "$install_dir/src/Solutions/wordpress.php"
chown "$app:$app" "$install_dir/src/Solutions/wordpress.php"
# Ship the field metadata the connector require's (src/Solutions/lib/wordpress/
# metadata.php). Without it setMetadata() returns nothing and no field is mappable.
mkdir -p "$install_dir/src/Solutions/lib/wordpress"
cp "$ynh_app_basedir/conf/wordpress-metadata.php" "$install_dir/src/Solutions/lib/wordpress/metadata.php"
chown -R "$app:$app" "$install_dir/src/Solutions/lib"
if ! grep -q "'wordpress'" "$install_dir/src/Manager/SolutionManager.php"; then
    sed -i "s#'iomad'#'iomad',\n\t\t\t\t\t\t\t'wordpress'#" "$install_dir/src/Manager/SolutionManager.php"
fi
if ! grep -q "wordpress \$wordpress" "$install_dir/src/Manager/SolutionManager.php"; then
    sed -i "s#iomad \$iomad#iomad \$iomad,\n        wordpress \$wordpress#" "$install_dir/src/Manager/SolutionManager.php"
fi
if ! grep -q "'wordpress'" "$install_dir/src/DataFixtures/LoadSolutionData.php"; then
    sed -i "/\['name' => 'moodle',/a\\        ['name' => 'wordpress', 'active' => 1, 'source' => 1, 'target' => 1]," "$install_dir/src/DataFixtures/LoadSolutionData.php"
fi

#=================================================
# PATCH FRONTEND ASSETS
#=================================================
# Three fixes applied before 'yarn build':
#  1. Force a single jQuery instance. jquery-ui 1.14 pulls its own nested jquery
#     copy, so its widgets attach to a different jQuery and $.fn.draggable is
#     missing on the one the app uses (why upstream fell back to a CDN). A
#     webpack alias collapses them to one instance.
#  2. Require jQuery UI early in the global 'app' entry (loaded on every page),
#     so $.fn.draggable etc. exist before any ready handler runs — no CDN.
#  3. Absolute publicPath matching the install path, so asset/image URLs resolve
#     on deep routes (default relative './build' 404s there).
ynh_script_progression --message="Patching frontend assets"

if ! grep -q "ynh: bundle jQuery UI" "$install_dir/assets/app.js"; then
    tmp_appjs="$(mktemp)"
    cat > "$tmp_appjs" <<'JS'
// ynh: bundle jQuery UI early, against the single aliased jQuery
require('jquery-ui');
require('jquery-ui/ui/widgets/draggable');
require('jquery-ui/ui/widgets/droppable');
require('jquery-ui/ui/widgets/sortable');
require('jquery-ui/ui/widgets/resizable');
require('jquery-ui/ui/widgets/dialog');
require('jquery-ui/ui/widgets/tabs');
require('jquery-ui/ui/widgets/accordion');
JS
    cat "$install_dir/assets/app.js" >> "$tmp_appjs"
    mv "$tmp_appjs" "$install_dir/assets/app.js"
    chown "$app:$app" "$install_dir/assets/app.js"
fi

if ! grep -q "addAliases({ jquery:" "$install_dir/webpack.config.js"; then
    sed -i "s#setManifestKeyPrefix('build/')#setManifestKeyPrefix('build/')\n    .addAliases({ jquery: require.resolve('jquery') })#" "$install_dir/webpack.config.js"
fi

public_path="${path%/}/build"
sed -i "s#setPublicPath('./build')#setPublicPath('$public_path')#" "$install_dir/webpack.config.js"

# Fix the hardcoded image base path in the JS. Several scripts build image URLs
# (e.g. solution logos) from global.path_img, which upstream hardcodes to
# '/build/images/' (or relative 'build/images/') with no install-path prefix, so
# they 404 on a subpath install. Point it at "<path>/build/images/".
path_img_base="${path%/}/build/images/"
sed -i "s#path_img = '/build/images/'#path_img = '$path_img_base'#g" \
    "$install_dir/assets/login.js" "$install_dir/assets/js/regle.js"
sed -i "s#path_img = 'build/images/'#path_img = '$path_img_base'#g" \
    "$install_dir/assets/app.js"

# Normalize the remaining (non-path_img) hard-coded image/base paths: the rule
# "createout" modal, connector status icons, and the document-detail AJAX/base
# helpers. Without this, solution logos, connector test icons and the interactive
# document-detail panels 404 on a subpath install. See _common.sh for details.
myddleware_fix_asset_paths

#=================================================
# NODE.JS + FRONTEND ASSETS
#=================================================
ynh_script_progression --message="Installing Node.js" --weight=10
ynh_install_nodejs --nodejs_version="$nodejs_version"
ynh_use_nodejs

# Yarn (classic) is not bundled with Node; install it into the Node prefix
# (as root, since the n-managed prefix is root-owned) so it lands on PATH.
ynh_exec_warn_less npm install -g yarn

# Run yarn with the process CWD and HOME inside the (app-owned) install dir.
# Yarn Classic walks up from the CWD reading .yarnrc files; if the CWD is under
# /var/cache/yunohost (root-only, mode 700) the app user hits EACCES, so we must
# cd into the install dir and pin HOME there rather than rely only on --cwd.
ynh_script_progression --message="Installing JS dependencies (yarn)" --weight=15
(cd "$install_dir" && sudo -u "$app" env PATH="$PATH" HOME="$install_dir" yarn install --frozen-lockfile)

ynh_script_progression --message="Building frontend assets (yarn build)" --weight=15
(cd "$install_dir" && sudo -u "$app" env PATH="$PATH" HOME="$install_dir" yarn build)

# Fail loudly if the build silently produced nothing (today's nastiest failure mode).
if [ ! -f "$install_dir/public/build/entrypoints.json" ]; then
    ynh_die --message="Asset build failed: public/build/entrypoints.json was not generated"
fi

#=================================================
# APPLICATION CONFIGURATION
#=================================================
ynh_script_progression --message="Generating application configuration"
mkdir -p "$install_dir/var/cache" "$install_dir/var/log"

db_name=$(ynh_app_setting_get --app="$app" --key=db_name)
db_user=$(ynh_app_setting_get --app="$app" --key=db_user)
db_pwd=$(ynh_app_setting_get --app="$app" --key=db_pwd)

secret=$(ynh_string_random --length=64)
jwt_passphrase=$(ynh_string_random --length=48)
ynh_app_setting_set --app="$app" --key=jwt_passphrase --value="$jwt_passphrase"

cat > "$install_dir/.env.local" <<ENV
APP_ENV=prod
APP_SECRET=$secret
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=$db_name
DATABASE_USER=$db_user
DATABASE_PASSWORD=$db_pwd
MAILER_URL=null://localhost
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=$jwt_passphrase
ENV
chmod 640 "$install_dir/.env.local"

#=================================================
# JWT KEY PAIR
#=================================================
ynh_script_progression --message="Generating JWT key pair"
mkdir -p "$install_dir/config/jwt"
openssl genpkey -algorithm RSA -out "$install_dir/config/jwt/private.pem" \
    -aes256 -pass "pass:$jwt_passphrase" -pkeyopt rsa_keygen_bits:4096
openssl pkey -in "$install_dir/config/jwt/private.pem" \
    -passin "pass:$jwt_passphrase" -pubout -out "$install_dir/config/jwt/public.pem"
chmod 640 "$install_dir/config/jwt/private.pem" "$install_dir/config/jwt/public.pem"

chown -R "$app:$app" "$install_dir"

# Run a Symfony console command as the app user with the full runtime env.
# CWD must be the install dir: some commands (e.g. fos:js-routing:dump) resolve
# relative paths against the process CWD, which otherwise points at the root-only
# /var/cache/yunohost work dir and fails with permission errors.
run_console() {
    (cd "$install_dir" && sudo -u "$app" env \
        APP_ENV=prod \
        APP_SECRET="$secret" \
        DATABASE_HOST=127.0.0.1 \
        DATABASE_PORT=3306 \
        DATABASE_NAME="$db_name" \
        DATABASE_USER="$db_user" \
        DATABASE_PASSWORD="$db_pwd" \
        JWT_PASSPHRASE="$jwt_passphrase" \
        php$phpversion "$install_dir/bin/console" "$@")
}

#=================================================
# DATABASE SCHEMA
#=================================================
ynh_script_progression --message="Creating database schema" --weight=5
if [ -x "$install_dir/bin/console" ]; then
    run_console doctrine:schema:create --no-interaction
fi

#=================================================
# LOAD INITIAL DATA
#=================================================
# Seed the foundational data (available solutions/connectors, config, cron jobs,
# functions). Without this the "solution" dropdown is empty and no connector or
# rule can be created. Fixtures are idempotent; --append avoids purging.
ynh_script_progression --message="Loading initial data" --weight=3
if [ -x "$install_dir/bin/console" ]; then
    run_console doctrine:fixtures:load --no-interaction --append
fi

#=================================================
# CACHE WARMUP
#=================================================
ynh_script_progression --message="Warming Symfony cache" --weight=3
run_console cache:clear --no-warmup
run_console cache:warmup

#=================================================
# DUMP JS ROUTES
#=================================================
ynh_script_progression --message="Dumping JS routes"
# Create the target dir as the app user so the dump (run as the app user) can
# write into it; run_console resolves the relative target against the install dir.
sudo -u "$app" mkdir -p "$install_dir/public/js"
run_console fos:js-routing:dump --format=json --target=public/js/fos_js_routes.json

#=================================================
# CREATE ADMIN USER
#=================================================
ynh_script_progression --message="Creating administrator account"
# YunoHost collects an email; derive a login username from its local part.
# myddleware:add-user signature is: <username> <password> <email> [--superadmin]
admin_username="${admin%%@*}"
admin_password=$(ynh_string_random --length=24)
ynh_app_setting_set --app="$app" --key=admin_username --value="$admin_username"
ynh_app_setting_set --app="$app" --key=admin_password --value="$admin_password"
run_console myddleware:add-user "$admin_username" "$admin_password" "$admin" --superadmin -n

chown -R "$app:$app" "$install_dir/var" "$install_dir/public"

#=================================================
# PHP-FPM AND NGINX CONFIGURATION
#=================================================
ynh_script_progression --message="Configuring PHP-FPM"
ynh_add_fpm_config --phpversion="$phpversion"

ynh_script_progression --message="Configuring NGINX"
ynh_add_nginx_config

#=================================================
# RELOAD SERVICES
#=================================================
ynh_script_progression --message="Reloading services"
ynh_systemd_action --service_name="php${phpversion}-fpm" --action=reload
ynh_systemd_action --service_name=nginx --action=reload
