#!/bin/bash
set -eu

source /usr/share/yunohost/helpers
source "$(dirname "$0")/_common.sh"

#=================================================
# STORE APP-SPECIFIC SETTINGS
#=================================================
ynh_app_setting_set --app="$app" --key=admin --value="$admin"
ynh_app_setting_set --app="$app" --key=phpversion --value="$phpversion"

#=================================================
# FETCH SOURCES
#=================================================
ynh_script_progression --message="Fetching Myddleware sources" --weight=2
ynh_setup_source --dest_dir="$install_dir"
chown -R "$app:$app" "$install_dir"

#=================================================
# COMPOSER DEPENDENCIES
#=================================================
ynh_script_progression --message="Installing Composer" --weight=2
ynh_install_composer --phpversion="$phpversion" --workdir="$install_dir" --composerversion=2.7.7

ynh_script_progression --message="Installing PHP dependencies" --weight=10
ynh_composer_exec --phpversion="$phpversion" --workdir="$install_dir" \
    --commands="install --optimize-autoloader"

#=================================================
# APPLICATION CONFIGURATION
#=================================================
ynh_script_progression --message="Generating application configuration"
mkdir -p "$install_dir/var/cache" "$install_dir/var/log"

secret=$(ynh_string_random --length=64)
cat > "$install_dir/.env.local" <<ENV
APP_ENV=prod
APP_SECRET=$secret
DATABASE_URL="mysql://$db_user:$db_pwd@localhost:3306/$db_name"
MAILER_URL=null://localhost
ENV
chown -R "$app:$app" "$install_dir"
chmod 640 "$install_dir/.env.local"

#=================================================
# DATABASE MIGRATIONS
#=================================================
ynh_script_progression --message="Running database migrations" --weight=5
if [ -x "$install_dir/bin/console" ]; then
    sudo -u "$app" php$phpversion "$install_dir/bin/console" \
        doctrine:migrations:migrate --no-interaction
fi

#=================================================
# PHP-FPM AND NGINX CONFIGURATION
#=================================================
ynh_script_progression --message="Configuring PHP-FPM"
ynh_add_fpm_config --phpversion="$phpversion"

ynh_script_progression --message="Configuring NGINX"
ynh_add_nginx_config

#=================================================
# RELOAD SERVICES
#=================================================
ynh_script_progression --message="Reloading services"
ynh_systemd_action --service_name="php${phpversion}-fpm" --action=reload
ynh_systemd_action --service_name=nginx --action=reload
